# Keys below sync automatically from Cursor secrets via: bash scripts/install.sh
# You should NOT hand-edit secrets — add them in Cursor → Secrets.

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Chief Manager — specialist workers + work-duration budgets (see docs/AGENT_MANAGER.md)
MANAGER_ENABLED=true
MANAGER_WORK_FLOOR_SECONDS=30
MANAGER_MAX_WORK_SECONDS=7200
MANAGER_ASYNC_THRESHOLD_SECONDS=120
MANAGER_WORK_PRIORITY=research
MANAGER_AUTO_DELEGATE=true
MANAGER_DEFAULT_RESEARCH_SECONDS=180
MANAGER_RESEARCH_FORCE_REFRESH=false
YOUTUBE_CHANNEL_NAME=Your Channel Name Here

DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_PUBLIC_KEY=your-discord-public-key-hex
DISCORD_OWNER_ID=your-discord-user-id
DISCORD_NOTIFY_IDS=
DISCORD_SEND_BRIEFING_ON_START=true
DISCORD_BRIEFING_HOUR=8
DISCORD_BRIEFING_MINUTE=30
DISCORD_AVATAR_PATH=channel/brand/assets/discord_bot_avatar.png
DISCORD_SET_AVATAR_ON_START=false

# Paid stack — Resemble + Gemini transcript/vision (defaults applied by sync_secrets if missing)
REQUIRE_PAID_STACK=true
ALLOW_FREE_TTS_FALLBACK=false
ALLOW_SCRIPT_TIMING_FALLBACK=false
TRANSCRIPT_PROVIDER=gemini
TRANSCRIPT_ALWAYS_FRESH=false

# Voice — Resemble clone
TTS_PROVIDER=resemble
RESEMBLE_API_KEY=your-resemble-api-key
RESEMBLE_VOICE_UUID=your-cloned-voice-uuid
RESEMBLE_PROJECT_UUID=
RESEMBLE_USE_HD=true
AUTO_GENERATE_VOICE=true

# Autopilot
AUTO_APPROVE_DRAFTS=true
AUTO_UPLOAD_YOUTUBE=true
YOUTUBE_UPLOAD_VISIBILITY=public
YOUTUBE_DECLARE_SYNTHETIC_MEDIA=true
AUTO_PUBLISH_HOURS=0

# Vision QC — Gemini (5 frames, 1 call)
VISION_QC_ENABLED=true
VISION_QC_BLOCKS_UPLOAD=true
VISION_QC_MIN_SCORE=7

# Optional AssemblyAI fallback (not required if GEMINI_API_KEY is set)
# ASSEMBLYAI_API_KEY=

# YPP guard
YPP_SAFE_MODE=true
MAX_UPLOADS_PER_24H=1
MIN_HOURS_BETWEEN_UPLOADS=20
TOPIC_COOLDOWN_DAYS=7
HOOK_COOLDOWN_DAYS=14
MAX_SCRIPT_OVERLAP_RATIO=0.65
BLOCK_DUPLICATE_DRAFT_UPLOAD=true
BLOCK_DUPLICATE_TITLE_UPLOAD=true

VISUAL_STYLE=stickfigure
IMAGE_PROVIDER=replicate
REPLICATE_API_TOKEN=your-replicate-api-token
REPLICATE_IMAGE_MODEL=[REDACTED]
FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell
IMAGE_ASPECT_RATIO=9:16

CAPTION_MODE=ffmpeg
BURN_IN_SUBTITLES=true
VIDEO_CRF=18
VIDEO_PRESET=slow
VIDEO_AUDIO_BITRATE_K=192
VIDEO_KEN_BURNS=false
VIDEO_MIN_DURATION_SECONDS=20
VIDEO_MAX_DURATION_SECONDS=58
VIDEO_QC_BLOCKS_UPLOAD=true

PRODUCTION_VARIETY_ENABLED=true
QUALITY_GATE_BLOCKS_RENDER=true
QUALITY_GATE_BLOCKS_UPLOAD=true

RESEARCH_CACHE_DAYS=7
DAILY_RESEARCH_FORCE_REFRESH=true
AUTO_DAILY_ENABLED=true
AUTO_DAILY_HOUR=11
AUTO_DAILY_MINUTE=0

# YouTube connect (once at home): python3 -m shorts_bot.youtube.auth_cli
# Grants Analytics + API upload — system browser Google sign-in, NOT Playwright Studio.
