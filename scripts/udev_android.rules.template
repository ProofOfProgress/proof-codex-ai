# udev rules for Android phones — install on hub laptop (WSL) when phones arrive.
# Copy to /etc/udev/rules.d/51-android-hub.rules then: sudo udevadm control --reload
#
# Replace VENDOR and PRODUCT with values from: lsusb (after usbipd attach)
# Example generic Google/Pixel-style IDs — update per your phones.

# SUBSYSTEM=="usb", ATTR{idVendor}=="18d1", ATTR{idProduct}=="4ee2", MODE="0666", GROUP="plugdev"
# SUBSYSTEM=="usb", ATTR{idVendor}=="2717", ATTR{idProduct}=="ff40", MODE="0666", GROUP="plugdev"

# Allow adb access without root for plugdev group members
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", MODE="0666", GROUP="plugdev"
