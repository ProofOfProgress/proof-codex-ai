# Desktop helper token — paste on ONE line, NO spaces before or after the token.
# Same value as Cursor → Cloud Agent → Secrets → DESKTOP_HELPER_TOKEN
DESKTOP_HELPER_TOKEN=paste-your-token-here-no-spaces

# KeyFreeze — lock local keyboard/mouse while agent runs (see docs/FOR_OWNER_KEYFREEZE.md)
# Do NOT paste your private hotkey in chat — keep it here on the hub only.
KEYFREEZE_EXE=C:\Tools\KeyFreeze\KeyFreeze.exe
KEYFREEZE_HOTKEY=ctrl+alt+f
# KEYFREEZE_COUNTDOWN_SECONDS=6
