{
  "name": "daily_invideo_v1",
  "description": "One InVideo prompt → credit check (≤10) → download → schedule upload. No AI twin.",
  "steps": [
    {
      "id": "pick_product",
      "action": "pick_next_product",
      "params": {"queue": "data/product_queue.json"}
    },
    {
      "id": "draft",
      "action": "create_draft",
      "params": {"format": "conversational_review", "no_twin": true}
    },
    {
      "id": "invideo_ship",
      "action": "invideo_autonomous_ship",
      "params": {
        "max_credits": 10,
        "tier": "basic",
        "no_twin": true,
        "one_prompt_only": true
      }
    },
    {
      "id": "upload",
      "action": "schedule_upload",
      "params": {"min_gap_hours": 20}
    },
    {
      "id": "analytics",
      "action": "sync_analytics_honest",
      "params": {"report": true}
    }
  ],
  "schedule": "every 24h",
  "owner_loop": "docs/FOR_OWNER_LOOP.md"
}
